# Copy this file to ".env" and fill in your own values.
# Values here override the built-in defaults; shell env vars win over this file.

DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=article

# Dashboard server port
PORT=8080

# Set to "true" to drop & re-migrate all tables on startup
RESET_DB=false
